import 'package:flutter/cupertino.dart';
import 'package:flutter/material.dart';
import 'package:flutter_animate/flutter_animate.dart';
import 'package:guideapp/video_player_screen.dart';
import 'package:percent_indicator/percent_indicator.dart';

class AICoGuideScreen extends StatefulWidget {
  const AICoGuideScreen({super.key});

  @override
  State<AICoGuideScreen> createState() => _AICoGuideScreenState();
}

class _AICoGuideScreenState extends State<AICoGuideScreen> {
  double _progress = 0.33; // Mock progress

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('AI Co-Guide'),
        actions: [
          Padding(
            padding: const EdgeInsets.only(right: 16.0),
            child: Row(
              children: [
                const Icon(CupertinoIcons.bolt_fill, color: Colors.amber),
                const SizedBox(width: 4),
                Text('150', style: TextStyle(fontWeight: FontWeight.bold, fontSize: 16)),
              ],
            ),
          )
        ],
      ),
      body: ListView(
        padding: const EdgeInsets.all(16.0),
        children: [
          Card(
            child: Padding(
              padding: const EdgeInsets.all(16.0),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  const Text('Your Learning Progress', style: TextStyle(fontWeight: FontWeight.bold)),
                  const SizedBox(height: 16),
                  LinearPercentIndicator(
                    lineHeight: 20.0,
                    percent: _progress,
                    center: Text('${(_progress * 100).toInt()}%', style: TextStyle(color: Colors.white, fontWeight: FontWeight.bold)),
                    barRadius: const Radius.circular(10),
                    backgroundColor: Colors.grey.shade300,
                    progressColor: Colors.blue,
                    animateFromLastPercent: true,
                    animation: true,
                  ),
                ],
              ),
            ),
          ),
          const SizedBox(height: 24),
          _buildVideoCard(
            context,
            title: 'The Red Fort',
            subtitle: 'Delhi',
            assetPath: 'assets/video_redfort.mp4',
            color: Colors.red.shade100,
            icon: Icons.fort,
          ),
          _buildVideoCard(
            context,
            title: 'The Taj Mahal',
            subtitle: 'Agra',
            assetPath: 'assets/video_taj.mp4',
            color: Colors.lightBlue.shade100,
            icon: CupertinoIcons.building_2_fill,
          ),
           _buildVideoCard(
            context,
            title: 'Amber Fort',
            subtitle: 'Jaipur',
            assetPath: 'assets/video_amber.mp4',
            color: Colors.amber.shade100,
            icon: Icons.castle,
          ),
        ].animate(interval: 100.ms).fadeIn().slideY(begin: 0.2),
      ),
    );
  }

  Widget _buildVideoCard(BuildContext context, {required String title, required String subtitle, required String assetPath, required Color color, required IconData icon}) {
    return Card(
      color: color,
      child: InkWell(
        onTap: () => Navigator.push(context, MaterialPageRoute(builder: (_) => VideoPlayerScreen(videoAssetPath: assetPath))),
        child: Padding(
          padding: const EdgeInsets.all(16.0),
          child: Row(
            children: [
              Icon(icon, size: 40, color: Colors.black.withOpacity(0.6)),
              const SizedBox(width: 16),
              Expanded(
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Text(title, style: const TextStyle(fontWeight: FontWeight.bold, fontSize: 16)),
                    Text(subtitle, style: TextStyle(color: Colors.black.withOpacity(0.6))),
                  ],
                ),
              ),
              const Icon(Icons.play_circle_fill_rounded, color: Colors.white, size: 40),
            ],
          ),
        ),
      ),
    );
  }
}
